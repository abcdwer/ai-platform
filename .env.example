# AI Platform - Environment Configuration Template
# Copy this file to .env in the same directory and configure your values
# For Docker deployment: backend/.env
# For local development: backend/.env and frontend/.env.local

# ===========================================
# Application Settings
# ===========================================
APP_NAME="AI Platform"
APP_VERSION="0.1.0"
DEBUG=false
NODE_ENV=production

# ===========================================
# Server Configuration
# ===========================================
HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aiplatform

# Connection URL (used by Docker Compose)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/aiplatform
# DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/aiplatform

# ===========================================
# Redis Cache
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ===========================================
# ChromaDB Vector Database
# ===========================================
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ===========================================
# Ollama (Local Models)
# ===========================================
# For local development with Ollama running on host machine:
# - macOS/Windows: http://host.docker.internal:11434
# - Linux: http://172.17.0.1:11434 (or your host IP)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama2

# ===========================================
# OpenAI (Cloud Models)
# ===========================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4-turbo-preview

# ===========================================
# Anthropic (Claude)
# ===========================================
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-opus-20240229

# ===========================================
# Security
# ===========================================
# IMPORTANT: Change this secret key in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# CORS (Cross-Origin Resource Sharing)
# ===========================================
# Origins allowed to access the API
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost"]

# ===========================================
# File Upload Settings
# ===========================================
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads

# ===========================================
# Knowledge Base Settings
# ===========================================
KNOWLEDGE_BASE_CHUNK_SIZE=1000
KNOWLEDGE_BASE_CHUNK_OVERLAP=200

# ===========================================
# Agent & Workflow Settings
# ===========================================
MAX_AGENT_STEPS=50
AGENT_TIMEOUT=300
WORKFLOW_MAX_EXECUTION_TIME=3600

# ===========================================
# LoRA Fine-tuning Settings
# ===========================================
LORA_OUTPUT_DIR=./models
LORA_TRAINING_DATA_DIR=./training_data

# ===========================================
# MCP Server Settings
# ===========================================
MCP_SERVER_CONFIG_DIR=./mcp_config

# ===========================================
# Frontend Settings (used in frontend/.env.local)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Platform
