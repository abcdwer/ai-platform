# AI Platform Backend - Environment Configuration
# Copy this file to .env and configure your values

# ===========================================
# Application Settings
# ===========================================
APP_NAME="AI Platform"
APP_VERSION="0.1.0"
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Docker Compose internal connection (uses service name)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/aiplatform
DATABASE_SYNC_URL=postgresql://postgres:postgres@postgres:5432/aiplatform

# Local development connection
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aiplatform
# DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/aiplatform

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://redis:6379/0
# For local: REDIS_URL=redis://localhost:6379/0

# ===========================================
# ChromaDB (Vector Database)
# ===========================================
CHROMA_HOST=chromadb
CHROMA_PORT=8000
# For local: CHROMA_HOST=localhost, CHROMA_PORT=8001

# ===========================================
# Ollama (Local Models)
# ===========================================
# For Docker Desktop (macOS/Windows)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# For Linux: OLLAMA_BASE_URL=http://172.17.0.1:11434
# For local without Docker: OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_DEFAULT_MODEL=llama2

# ===========================================
# OpenAI (Cloud Models)
# ===========================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4-turbo-preview

# ===========================================
# Anthropic (Claude)
# ===========================================
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-opus-20240229

# ===========================================
# Security
# ===========================================
# IMPORTANT: Change this secret key in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost"]

# ===========================================
# File Upload
# ===========================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ===========================================
# Knowledge Base
# ===========================================
KNOWLEDGE_BASE_CHUNK_SIZE=1000
KNOWLEDGE_BASE_CHUNK_OVERLAP=200

# ===========================================
# Agent & Workflow
# ===========================================
MAX_AGENT_STEPS=50
AGENT_TIMEOUT=300
WORKFLOW_MAX_EXECUTION_TIME=3600

# ===========================================
# LoRA Fine-tuning
# ===========================================
LORA_OUTPUT_DIR=./models
LORA_TRAINING_DATA_DIR=./training_data

# ===========================================
# MCP Server
# ===========================================
MCP_SERVER_CONFIG_DIR=./mcp_config
